# ==============================================================================
# GigaAM v3 Transcriber - Конфигурация окружения
# ==============================================================================
# 
# ИНСТРУКЦИЯ ПО ИСПОЛЬЗОВАНИЮ:
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Откройте .env и заполните все необходимые значения
# 3. НЕ коммитьте .env в Git! Файл уже добавлен в .gitignore
#
# ==============================================================================

# ==================== HuggingFace Configuration ====================
# ОБЯЗАТЕЛЬНО! Токен для доступа к моделям HuggingFace
# 
# Как получить токен:
# 1. Зарегистрируйтесь на https://huggingface.co
# 2. Создайте токен: https://huggingface.co/settings/tokens
#    - Выберите тип токена: "Read" (достаточно для загрузки моделей)
# 3. Примите условия использования модели:
#    https://huggingface.co/pyannote/segmentation-3.0
# 4. Скопируйте токен и вставьте ниже (токен начинается с "hf_")
#
HF_TOKEN=your_huggingface_token_here

# Web GUI auth. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WEB_SECRET=replace_with_32plus_byte_random_secret
WEB_USERNAME=dubr1k
WEB_PASSWORD=replace_with_strong_password

# Единый корень для PyTorch runtime и всех моделей. Специализированные
# *_DIR/HF_HOME переменные, если заданы, имеют приоритет над соответствующей
# подпапкой. В Desktop GUI тот же выбор доступен через меню «Настройки».
# GIGAAM_DATA_DIR=/path/on/large/disk/GigaAMData

# ==================== Application Settings (GUI) ====================
# Настройки графического интерфейса (используются только в app.py)

# Заголовок окна приложения
APP_TITLE=GigaAM v3 Transcriber

# Размер окна (ширина x высота)
APP_GEOMETRY=900x700

# Цветовая тема (blue, green, dark-blue)
APP_THEME=blue

# ==================== Audio Settings ====================
# Настройки обработки аудио

# Частота дискретизации (Гц). Рекомендуется: 16000
AUDIO_SAMPLE_RATE=16000

# Количество каналов (1 = моно, 2 = стерео). Рекомендуется: 1
AUDIO_CHANNELS=1

# Интеллектуальная подготовка: off | auto | light | denoise
AUDIO_PREPROCESSING_MODE=auto

# Опциональный writable+executable cache для self-contained DeepFilterNet binary.
# Обычно определяется автоматически. Нужен для hardened/noexec окружений.
# GIGAAM_DEEPFILTER_DIR=/path/to/executable/cache

# ==================== Model Settings ====================
# Настройки модели транскрибации

# Имя модели на HuggingFace
MODEL_NAME=ai-sage/GigaAM-v3

# Ревизия модели (версия)
MODEL_REVISION=e2e_rnnt

# ASR backend selection
# auto | mlx | pytorch
ASR_BACKEND=auto

# Модель для ASR backend
ASR_MODEL=e2e_rnnt

# Разрешить fallback (auto only): mlx -> pytorch
ASR_ALLOW_FALLBACK=true

# Сегментация ASR:
# vad (рекомендуется) | overlap_chunks (без VAD, тихие точки + overlap) |
# fixed_chunks (legacy до 20 сек. без overlap)
ASR_SEGMENTATION_MODE=vad

# Устройство pyannote VAD: cpu по умолчанию не занимает память GPU рядом с
# GigaAM. auto выберет CUDA/MPS, если памяти ускорителя заведомо хватает.
ASR_VAD_DEVICE=cpu

# ONNX Runtime execution provider: auto/cpu/cuda/tensorrt/coreml/directml
ONNX_PROVIDER=auto
# Опциональная INT8-квантизация моделей onnx-asr; оставьте пустым для FP32/FP16.
ONNX_QUANTIZATION=
# Необязательная локальная директория моделей onnx-asr.
ONNX_MODEL_DIR=
# VAD-модель onnx-asr (по умолчанию лёгкий Silero).
ONNX_VAD_MODEL=silero

# Рекомендуемый MLX репозиторий модели
MLX_MODEL_REPO=aystream/GigaAM-v3-e2e-rnnt-mlx


# ==================== Statistics ====================
# Файл для сохранения статистики обработки
STATS_FILE=processing_stats.json

# ==================== LLM API Configuration ====================
# Настройки LLM для вкладки пост-обработки транскриптов
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.2

# ==================== API Configuration ====================
# Настройки REST API (используются только в api.py)

# --- API Server ---
# Хост для запуска API сервера
# 127.0.0.1 - только локальный доступ
# 0.0.0.0 - доступ из сети
API_HOST=127.0.0.1

# Порт для API сервера
API_PORT=8000

# Количество воркеров (для production)
API_WORKERS=2

# Автоперезагрузка при изменении кода (только для разработки)
API_RELOAD=false

# --- API Limits ---
# Максимальный размер файла в байтах (2GB = 2147483648)
MAX_FILE_SIZE=2147483648

# Максимальное количество одновременных задач обработки
MAX_CONCURRENT_TASKS=3

# Время хранения результатов в часах (после этого задачи удаляются)
TASK_CLEANUP_HOURS=24

# --- API Rate Limiting ---
# Ограничение скорости загрузки файлов (формат: число/период)
# Примеры: "10/minute", "100/hour", "1000/day"
RATE_LIMIT_UPLOAD=10/minute

# Общее ограничение скорости для API запросов
RATE_LIMIT_API=30/minute

# --- API Security ---
# Файл с API ключами для доступа к API (хранятся только SHA-256 хэши ключей)
# Будет создан автоматически при первом запуске API
# Первый ключ будет сгенерирован и выведен в консоль ОДИН РАЗ — сохраните его!
API_KEYS_FILE=.api_keys

# Разрешённые источники для CORS (через запятую). По умолчанию пусто =
# кросс-доменные запросы из браузера запрещены. Пример:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Возвращать ли клиенту полный traceback ошибок обработки (НЕБЕЗОПАСНО,
# только для отладки). По умолчанию false — клиенту уходит обобщённое сообщение.
API_DEBUG=false

# --- API Directories ---
# Директория для временных загруженных файлов
UPLOAD_DIR=uploads

# Директория для сохранения результатов транскрибации
RESULTS_DIR=results

# --- API Domain (опционально, для документации) ---
# Домен вашего API (используется только в документации)
API_DOMAIN=your-domain.com

# Базовый URL вашего API (используется только в документации)
API_BASE_URL=https://your-domain.com

# ==============================================================================
# ПРИМЕЧАНИЯ:
# - Все значения можно оставить по умолчанию, кроме HF_TOKEN (обязательно!)
# - После изменения .env файла перезапустите приложение
# - Для production рекомендуется изменить API_HOST на 0.0.0.0
# - Убедитесь, что директории UPLOAD_DIR и RESULTS_DIR существуют или будут созданы автоматически
# ==============================================================================
